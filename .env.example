# Copy this file to .env and fill in your own keys.
# Do not commit .env, cookies.txt, videos, or generated project outputs.

# ElevenLabs Speech to Text
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_STT_LANGUAGE_CODE=jpn

# Google Gemini translation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_THINKING_LEVEL=HIGH

# DeepSeek structural fix layer
DEEPSEEK_API_KEY=
LLM_CHUNK_FIX_MAX_RETRIES=3

# Translation chunking
GEMINI_CHUNK_CHAR_LIMIT=6000
GEMINI_CONCURRENCY=10
GEMINI_CHUNK_MAX_RETRIES=3
GEMINI_CHUNK_MISSING_BLOCK_TOLERANCE=2

# Video frame sampling for Gemini context
GEMINI_PRE_PASS_FRAME_INTERVAL_SECONDS=120
GEMINI_PRE_PASS_FRAME_MAX_SIDE=768
GEMINI_CHUNK_FRAME_INTERVAL_SECONDS=30
GEMINI_CHUNK_FRAME_MAX_SIDE=768
GEMINI_INTRO_SKIP_SECONDS=3.0

# Optional features
ENABLE_SRT_REFINE=false
ENABLE_GLOSSARY_CHECK=false
ENABLE_COVER_GENERATION=false
ENABLE_GEMINI_CLI_PREPASS=false
ENABLE_FULL_FIXED_GLOSSARY=false

# Optional Gemini CLI backend
GEMINI_CLI_EXECUTABLE=gemini
GEMINI_CLI_MODEL=gemini-3.1-pro-preview
GEMINI_CLI_TIMEOUT_SECS=900
GEMINI_CLI_MAX_RETRIES=3

# Optional Codex post-processing
CODEX_EXECUTABLE=codex
CODEX_DEFAULT_TIMEOUT_SECS=900

# yt-dlp cookies
COOKIES_TXT_PATH=cookies.txt

# Optional archive/package paths
ARCHIVED_PATH=
PACKAGE_PATH=
